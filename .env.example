# Required for embeddings/chat (host machine or api container)
GITHUB_TOKEN=

# GitHub Models inference (default shown)
INFERENCE_ENDPOINT=https://models.github.ai/inference
CHAT_MODEL=openai/o4-mini
EMBEDDING_MODEL=openai/text-embedding-3-small

# MongoDB — use directConnection for Atlas Local / single-node
MONGODB_URI=mongodb://127.0.0.1:27017/?directConnection=true
MONGODB_DB=localrag

REDIS_URL=redis://127.0.0.1:6379

# API listens here (compose maps 3002:3002)
API_PORT=3002

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_INGEST_BYTES=1048576

# Chat memory
CHAT_HISTORY_TTL_SECONDS=86400
CHAT_HISTORY_MAX_MESSAGES=20

# Next.js (browser → API). In compose use http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3002
